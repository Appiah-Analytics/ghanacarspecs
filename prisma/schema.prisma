// Local development database (SQLite). Production uses schema.postgresql.prisma — see docs/postgresql.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum EventType {
  IMPORT
  REGISTRATION
  SERVICE
  ACCIDENT
  INSURANCE_CLAIM
  MILEAGE_UPDATE
  THEFT
  OTHER
}

enum PhotoSourceType {
  IMPORT_CONDITION
  INSPECTION
  ACCIDENT_REPAIR
  AUCTION
  OTHER
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
  VERIFIED
}

enum ProvenanceType {
  DEMO
  USER_SUBMITTED
  DEALER
  IMPORTER
  AUCTION
  INTERNAL
  GOVERNMENT
  INSURER
  POLICE
  OTHER
}

model Vehicle {
  id               String          @id @default(cuid())
  vin              String          @unique
  chassisNumber    String?         @unique
  plateNumber      String?
  make             String
  model            String
  year             Int
  trim             String?
  engineType       String?
  engineSize       String?
  fuelType         String?
  countryOfOrigin  String?
  importDate       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  events           VehicleEvent[]
  photos           VehiclePhoto[]

  @@map("vehicles")
}

model VehiclePhoto {
  id              String          @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url             String
  caption         String
  sourceType      PhotoSourceType
  sourceLabel     String?
  takenAt         DateTime?
  confidenceLevel ConfidenceLevel @default(LOW)
  provenanceType  ProvenanceType  @default(OTHER)
  createdAt       DateTime        @default(now())

  @@index([vehicleId])
  @@map("vehicle_photos")
}

model VehicleEvent {
  id              String          @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  eventType       EventType
  eventDate       DateTime
  mileage         Int?
  sourceSystem    String?
  rawPayload      Json?
  confidenceLevel ConfidenceLevel @default(LOW)
  provenanceType  ProvenanceType  @default(OTHER)
  createdAt       DateTime        @default(now())

  @@index([vehicleId])
  @@map("vehicle_events")
}
