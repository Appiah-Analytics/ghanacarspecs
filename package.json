{
  "name": "ghanacarspecs",
  "version": "0.1.0",
  "private": true,
  "description": "GhanaCarSpecs — vehicle history and specs platform (monorepo root).",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "node scripts/production-build.mjs",
    "build:local": "npm run db:generate && next build",
    "vercel-build": "node scripts/production-build.mjs",
    "start": "next start",
    "lint": "tsc --noEmit",
    "postinstall": "node scripts/prisma-generate.mjs",
    "db:generate": "prisma generate",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgresql.prisma",
    "db:push": "prisma db push",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgresql.prisma",
    "db:migrate:postgres": "prisma migrate deploy --schema prisma/schema.postgresql.prisma",
    "db:migrate:postgres:dev": "prisma migrate dev --schema prisma/schema.postgresql.prisma",
    "db:seed": "prisma db seed",
    "db:seed:postgres": "prisma db seed --schema prisma/schema.postgresql.prisma",
    "db:setup": "prisma db push && prisma db seed",
    "db:setup:postgres": "npm run db:generate:postgres && prisma migrate deploy --schema prisma/schema.postgresql.prisma && npm run db:seed:postgres",
    "db:export:sqlite": "tsx scripts/export-sqlite-data.ts",
    "db:import:postgres": "tsx scripts/import-postgres-data.ts",
    "report:docx": "tsx scripts/generate-progress-report.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@vercel/blob": "^2.4.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "docx": "^9.6.1",
    "prisma": "^6.19.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
