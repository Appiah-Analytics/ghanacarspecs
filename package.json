{
  "name": "ghanacarspecs",
  "version": "0.1.0",
  "private": true,
  "description": "GhanaCarSpecs — vehicle history and specs platform (monorepo root).",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:setup": "prisma db push && prisma db seed",
    "report:docx": "tsx scripts/generate-progress-report.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "docx": "^9.6.1",
    "prisma": "^6.19.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
