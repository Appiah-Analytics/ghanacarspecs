# GhanaCarSpecs — copy to `.env` at the repo root (same folder as package.json).
# Restart `npm run dev` after any change. Production: use host secret store, not git.

# -----------------------------------------------------------------------------
# Admin protection (required for /admin and /api/admin/*)
# -----------------------------------------------------------------------------

# IMPORTANT: lines must be UNCOMMENTED (no leading #). Example:
ADMIN_API_KEY=change-me-to-a-long-random-string
# ADMIN_PASSWORD=use-instead-if-you-prefer

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Local SQLite (default): leave DATABASE_URL unset or commented out.
# The app and `npm run db:seed` use prisma/dev.db automatically.
# Do NOT point DATABASE_URL at Neon for normal local dev — photos and seed data
# would be on different databases.

# PostgreSQL (optional local test against Neon): set BOTH:
# USE_POSTGRES_LOCAL=1
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ghanacarspecs?sslmode=require"
# Then: npm run db:generate:postgres && npm run db:migrate:postgres && npm run db:seed

# -----------------------------------------------------------------------------
# Runtime (optional)
# -----------------------------------------------------------------------------

# PORT=3000

# -----------------------------------------------------------------------------
# Optional (not read by the app yet)
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_APP_URL=http://localhost:3000
