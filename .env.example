# GhanaCarSpecs — copy to `.env` for local overrides (optional today).
# Production: set in the host secret store (e.g. Azure App Service), not in git.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Set automatically by Next.js in most cases; override only if needed.
# NODE_ENV=development

# Port for `npm run start` (optional; default 3000)
# PORT=3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Not read by Prisma yet — schema uses url = "file:./dev.db" in prisma/schema.prisma.
# Uncomment and switch schema to env("DATABASE_URL") before production (PostgreSQL).
# DATABASE_URL="file:./dev.db"

# Production example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ghanacarspecs?sslmode=require"

# -----------------------------------------------------------------------------
# App URL (planned — not read by app yet)
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Security (planned — required before public admin routes)
# -----------------------------------------------------------------------------

# ADMIN_API_KEY=
# AUTH_SECRET=
