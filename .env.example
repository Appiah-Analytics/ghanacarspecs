# GhanaCarSpecs — copy to `.env` at the repo root (same folder as package.json).
# Restart `npm run dev` after any change. Production: use host secret store, not git.

# -----------------------------------------------------------------------------
# Admin protection (required for /admin and /api/admin/*)
# -----------------------------------------------------------------------------

# IMPORTANT: lines must be UNCOMMENTED (no leading #). Example:
ADMIN_API_KEY=change-me-to-a-long-random-string
# ADMIN_PASSWORD=use-instead-if-you-prefer

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Local SQLite (default): no DATABASE_URL needed — schema.prisma uses file:./dev.db

# PostgreSQL (staging/production only): required when using schema.postgresql.prisma
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ghanacarspecs?sslmode=require"

# -----------------------------------------------------------------------------
# Runtime (optional)
# -----------------------------------------------------------------------------

# PORT=3000

# -----------------------------------------------------------------------------
# Optional (not read by the app yet)
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_APP_URL=http://localhost:3000
